{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Docker Tray",
  "version": "0.2.0",
  "identifier": "com.yurseria.docker-tray",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Docker Tray",
        "width": 420,
        "height": 560,
        "resizable": true,
        "minWidth": 420,
        "maxWidth": 420,
        "minHeight": 300,
        "maxHeight": 900,
        "decorations": false,
        "skipTaskbar": true,
        "visible": false,
        "alwaysOnTop": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "icons/tray-icon.png",
      "runtime/**/*"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
